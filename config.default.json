{
    "_comment":  "Default deploy-safe configuration. Secret values are supplied through environment variables or Streamlit secrets.",
    "openai_api_key":  "${OPENAI_API_KEY}",
    "openai_model_name":  "gpt-4o-mini",
    "tavily_api_key":  "${TAVILY_API_KEY}",
    "schedule_cron":  "0 9 * * 4",
    "default_category":  "ALL",
    "smtp":  {
                 "server":  "${SMTP_SERVER}",
                 "port":  587,
                 "user":  "${SMTP_USER}",
                 "password":  "${SMTP_PASSWORD}",
                 "sender":  "${SMTP_SENDER}",
                 "recipients":  [
                                    "${SMTP_RECIPIENT_1}",
                                    "${SMTP_RECIPIENT_2}"
                                ]
             },
    "review_contacts":  {
                            "Release Team":  "${SMTP_RECIPIENT_1}",
                            "Security Team":  "${SMTP_RECIPIENT_1}",
                            "QA Team":  "${SMTP_RECIPIENT_1}",
                            "Platform Team":  "${SMTP_RECIPIENT_1}",
                            "Application Owner":  "${SMTP_RECIPIENT_1}",
                            "DBA Team":  "${SMTP_RECIPIENT_1}",
                            "Messaging Team":  "${SMTP_RECIPIENT_1}"
                        },
    "input_files":  {
                        "software_yml":  "Input/teams/SourceOne/releases/7.2.12/software.yml",
                        "current_version_pdf":  "Input/teams/SourceOne/releases/7.2.12/sample_version.pdf",
                        "testcase_repository_xlsx":  "Input/teams/SourceOne/releases/7.2.12/testcaseRepository.xlsx"
                    },
    "output_files":  {
                         "latest_version_json":  "output/latest_versions.json",
                         "current_version_json":  "output/current_versions.json",
                         "comparison_report_json":  "output/comparison_report.json",
                         "vulnerability_report_json":  "output/vulnerability_report.json",
                         "package_readiness_json":  "output/package_readiness.json",
                         "qa_validation_json":  "output/qa_validation.json",
                         "testcase_impact_json":  "output/testcase_impact.json",
                         "testcase_impact_xlsx":  "output/Test_Case_Impact_Assessment.xlsx",
                         "excel_assessment":  "output/Software_Version_Assessment.xlsx"
                     },
    "vulnerability":  {
                          "enabled":  true,
                          "nvd_api_key":  "${NVD_API_KEY}",
                          "timeout_seconds":  20
                      },
    "cache":  {
                  "enabled":  true,
                  "backend":  "json",
                  "directory":  "output/cache",
                  "metrics_file":  "output/cache/cache_metrics.json",
                  "software_versions_ttl_seconds":  604800,
                  "vulnerabilities_ttl_seconds":  86400
              },
    "auth":  {
                 "enabled":  true
             },
    "assistant_router":  {
                             "embedding_enabled":  false,
                             "embedding_model":  "text-embedding-3-small",
                             "embedding_threshold":  0.72,
                             "embedding_margin":  0.06,
                             "embedding_cache":  "output/cache/assistant_tool_embeddings.json"
                         },
    "users":  [
                  {
                      "username":  "admin",
                      "display_name":  "Administrator",
                      "password":  "admin",
                      "team_scope":  [
                                         "*"
                                     ],
                      "role":  "Admin"
                  }
              ]
}
